    "sql": "-- STEP 1: query [kommuner]\nSELECT \n  kommunenummer,\n  kommunenavn,\n  ST_AsGeoJSON(ST_Transform(omrade, 4326)) AS geom_geojson\nFROM kommuner_627ee106072240e99d2b21ec4717bf01.kommune \nWHERE kommunenummer = '4204'\n\n-- STEP BOUNDARY --\n\n-- STEP 2: query [stormflohavniva]\nSELECT \n  objid,\n  ST_AsGeoJSON(ST_Transform(omrade, 4326)) AS geom_geojson\nFROM stormflohavniva_bd7c84ed67254396b81e18b48ee0f525.stormflo200ar_klimaarna\n\n-- STEP BOUNDARY --\n\n-- STEP 3: spatial_join\n-- left_source: 1\n-- right_source: 2\n-- join_type: \"intersects\"\n-- left_geom: \"geom_geojson\"\n-- right_geom: \"geom_geojson\"\n\n-- STEP BOUNDARY --\n\n-- STEP 4: query [kommuner]\nWITH kristiansand AS (\n  SELECT \n    ST_Transform(omrade, 25833) AS geom_25833,\n    ST_Envelope(ST_Transform(omrade, 25833)) AS bbox\n  FROM kommuner_627ee106072240e99d2b21ec4717bf01.kommune \n  WHERE kommunenummer = '4204'\n),\ngrid AS (\n  SELECT \n    ST_SetSRID(ST_MakeEnvelope(\n      ST_XMin(bbox) + (x * 1000),\n      ST_YMin(bbox) + (y * 1000),\n      ST_XMin(bbox) + ((x + 1) * 1000),\n      ST_YMin(bbox) + ((y + 1) * 1000)\n    ), 25833) AS grid_cell\n  FROM kristiansand,\n  generate_series(0, floor((ST_XMax(bbox) - ST_XMin(bbox)) / 1000)::integer - 1) AS x,\n  generate_series(0, floor((ST_YMax(bbox) - ST_YMin(bbox)) / 1000)::integer - 1) AS y\n)\nSELECT \n  ROW_NUMBER() OVER () AS grid_id,\n  ST_AsGeoJSON(ST_Transform(grid_cell, 4326)) AS geom_geojson\nFROM grid\nWHERE ST_Intersects(grid_cell, (SELECT geom_25833 FROM kristiansand))\n\n-- STEP BOUNDARY --\n\n-- STEP 5: spatial_join\n-- left_source: 4\n-- right_source: 3\n-- join_type: \"intersects\"\n-- left_geom: \"geom_geojson\"\n-- right_geom: \"geom_geojson\"\n\n-- STEP BOUNDARY --\n\n-- STEP 6: aggregate\n-- source_step: 5\n-- aggregation_type: \"count\"\n-- metric_column: \"grid_id\"\n-- metric_as: \"grid_cell_count\"",
