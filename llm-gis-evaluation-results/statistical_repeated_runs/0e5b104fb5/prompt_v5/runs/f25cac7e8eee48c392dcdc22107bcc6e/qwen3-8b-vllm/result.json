    "sql": "SELECT DISTINCT ON (b.objid) b.objid, b.bygningid, b.kommunenummer, b.kommunenavn, b.representasjonspunkt\nFROM matrikkelenbygning.matrikkelenbygning_e58ed5b5abd74bc1a42ff55d569f0cf4.bygning b\nJOIN kvikkleire.kvikkleire_87067f98e29a47d4901328f3a926a515.utlosningomr u ON ST_Intersects(b.representasjonspunkt, u.omrade)\nWHERE b.kommunenavn = 'Trondheim' AND u.skredfaregradklasse = 'Høy' AND u.skredrisikokvikkleireklasse = 'Høy' AND u.skredskadekonsekvensklasse = 'Høy'\nORDER BY b.objid\nLIMIT 10;",
