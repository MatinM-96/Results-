    "sql": "SELECT DISTINCT ON (statistiskrutenett1km.befolkningparuter1km.omrade) statistiskrutenett1km.befolkningparuter1km.omrade, COUNT(matrikkeleneiendomskartteig.teig.teignummer) AS parcel_count FROM matrikkeleneiendomskartteig.teig JOIN statistiskrutenett1km.befolkningparuter1km ON ST_Intersects(matrikkeleneiendomskartteig.teig.geom, statistiskrutenett1km.befolkningparuter1km.omrade) WHERE ST_Intersects(matrikkeleneiendomskartteig.teig.geom, (SELECT grense FROM kommuner.kommune WHERE kommuner.kommune.kommunenavn = 'Lillestrøm')) GROUP BY statistiskrutenett1km.befolkningparuter1km.omrade ORDER BY parcel_count DESC LIMIT 5",
