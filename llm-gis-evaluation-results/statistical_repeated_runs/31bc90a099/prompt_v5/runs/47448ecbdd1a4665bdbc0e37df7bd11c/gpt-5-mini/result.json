        "action": "query",
        "database": "kommuner",
        "sql": "SELECT kommunenummer, kommunenavn,\n       ST_Extent(omrade) AS extent_geom,\n       ST_XMin(ST_Extent(omrade)) AS minx,\n       ST_YMin(ST_Extent(omrade)) AS miny,\n       ST_XMax(ST_Extent(omrade)) AS maxx,\n       ST_YMax(ST_Extent(omrade)) AS maxy\nFROM kommuner_627ee106072240e99d2b21ec4717bf01.kommune\nWHERE kommunenavn ILIKE '%Stavanger%'\nGROUP BY kommunenummer, kommunenavn;",
