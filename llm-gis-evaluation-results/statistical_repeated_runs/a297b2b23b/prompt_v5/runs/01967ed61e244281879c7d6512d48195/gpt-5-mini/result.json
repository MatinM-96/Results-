        "sql": "SELECT kommunenummer,\n  ST_XMin(ST_Envelope(ST_Transform(omrade,25833))) AS xmin,\n  ST_YMin(ST_Envelope(ST_Transform(omrade,25833))) AS ymin,\n  ST_XMax(ST_Envelope(ST_Transform(omrade,25833))) AS xmax,\n  ST_YMax(ST_Envelope(ST_Transform(omrade,25833))) AS ymax\nFROM kommuner_627ee106072240e99d2b21ec4717bf01.kommune\nWHERE kommunenavn ILIKE '%kristiansand%'\nLIMIT 1;",
        "success": true,
