    "sql": "SELECT DISTINCT ON (b.objektid) b.objektid, b.navn, ST_Distance(b.representasjonspunkt, q.geometry) AS distance_to_quick_clay\nFROM matrikkelenbygning.matrikkelenbygning_e58ed5b5abd74bc1a42ff55d569f0cf4.bygning b\nJOIN kommuner.kommuner_627ee106072240e99d2b21ec4717bf01.kommune k ON ST_Contains(k.omrade, b.representasjonspunkt)\nWHERE k.navn = 'Drammen'\nAND EXISTS (\n    SELECT 1\n    FROM flomsoner.flomsoner_92001766ec964ab8b545fef0a00e6d23.flomareal f\n    WHERE ST_Intersects(b.representasjonspunkt, f.omrade)\n    AND f.returnperiod = 200\n)\nORDER BY b.objektid, distance_to_quick_clay\nLIMIT 10;",
