    "sql": "-- STEP 1: query [kommuner]\nWITH muni AS (\n  SELECT kommunenummer, kommunenavn, omrade\n  FROM kommuner_627ee106072240e99d2b21ec4717bf01.kommune\n  WHERE kommunenavn ILIKE 'Trondheim%'\n), extent_geom AS (\n  SELECT kommunenummer, kommunenavn, ST_Envelope(ST_Collect(omrade)) AS env_geom\n  FROM muni\n  GROUP BY kommunenummer, kommunenavn\n)\nSELECT kommunenummer, kommunenavn,\n  ST_XMin(env_geom) AS minx, ST_YMin(env_geom) AS miny,\n  ST_XMax(env_geom) AS maxx, ST_YMax(env_geom) AS maxy,\n  ST_SRID(env_geom) AS srid\nFROM extent_geom\nLIMIT 1;\n\n-- STEP BOUNDARY --\n\n-- STEP 2: query [kvikkleire]\nSELECT kartleggingsomradeid, kartleggingsomradenavn, omrade FROM kvikkleire_175185730654415d8841436d0d6999f2.kartleggingsomrade\nWHERE omrade && ST_MakeEnvelope(250339.82999591084,7010675.560000021,285864.4299986598,7051059.450000035,25833);\n\n-- STEP BOUNDARY --\n\n-- STEP 3: query [matrikkelenbygning]\nSELECT bygningid, bygningsnummer, kommunenummer, representasjonspunkt FROM matrikkelenbygning_fe504ac373564e10b85865ef2a507c63.bygning WHERE kommunenummer = '5001';\n\n-- STEP BOUNDARY --\n\n-- STEP 4: spatial_join\n-- left_source: 3\n-- right_source: 2\n-- join_type: \"intersects\"\n-- left_geom: \"representasjonspunkt\"\n-- right_geom: \"omrade\"\n\n-- STEP BOUNDARY --\n\n-- STEP 5: aggregate\n-- source_step: 4\n-- aggregation_type: \"count\"\n-- group_by: [\"bygningid\"]\n-- metric_as: \"count\"\n\n-- STEP BOUNDARY --\n\n-- STEP 6: aggregate\n-- source_step: 5\n-- aggregation_type: \"count\"\n-- metric_as: \"count_distinct_buildings\"",
